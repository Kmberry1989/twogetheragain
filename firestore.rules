rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write to the couples collection and its subcollections 
    // (like activities and journalEntries) as long as they are authenticated.
    match /couples/{coupleId} {
      allow read, write: if request.auth != null;
      
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Fallback rule for any other collections you might add
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
